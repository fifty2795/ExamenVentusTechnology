@{
    ViewData["Title"] = "Tareas";
}

<div class="container py-4">

    <input type="hidden" id="IdTarea" />

    <div class="d-flex flex-column flex-md-row
                justify-content-between align-items-md-center
                gap-3 mb-4">

        <div>
            <h1 class="h3 mb-1">
                Administración de tareas
            </h1>

            <p class="text-muted mb-0">
                Consulta y administra las tareas del equipo.
            </p>
        </div>

        <a asp-controller="Tareas"
           asp-action="Crear"
           class="btn btn-primary">
            Nueva tarea
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <h2 class="h5 mb-3">
                Filtros
            </h2>

            <div class="row g-3">

                <div class="col-12 col-md-4 col-lg-3">
                    <label for="filtroPrioridad"
                           class="form-label">
                        Prioridad
                    </label>

                    <select id="filtroPrioridad"
                            name="filtroPrioridad"
                            class="form-select">
                        <option value="">
                            Todas
                        </option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label for="filtroEstatus"
                           class="form-label">
                        Estatus
                    </label>

                    <select id="filtroEstatus"
                            name="filtroEstatus"
                            class="form-select">
                        <option value="">
                            Todos
                        </option>
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label for="filtroUsuario"
                           class="form-label">
                        Responsable
                    </label>

                    <select id="filtroUsuario"
                            name="filtroUsuario"
                            class="form-select">
                        <option value="">
                            Todos
                        </option>
                    </select>
                </div>
            </div>

            <br />            

            <div class="row g-3">

                <div class="col-12 col-md-6 col-lg-3">
                    <label for="filtroFechaInicial"
                           class="form-label">
                        Fecha inicial
                    </label>

                    <input type="date"
                           id="filtroFechaInicial"
                           class="form-control" />
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label for="filtroFechaFinal"
                           class="form-label">
                        Fecha final
                    </label>

                    <input type="date"
                           id="filtroFechaFinal"
                           class="form-control" />
                </div>

                <div class="col-12 col-lg-6 d-flex
                            align-items-end gap-2">

                    <button type="button"
                            id="btnBuscar"
                            class="btn btn-primary">
                        Buscar
                    </button>

                    <button type="button"
                            id="btnLimpiar"
                            class="btn btn-outline-secondary">
                        Limpiar
                    </button>
                </div>

            </div>

        </div>
    </div>

    <hr />

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">

                <table id="tblTareas"
                       class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th class="text-center" scope="col">
                                Título
                            </th>

                            <th class="text-center" scope="col">
                                Prioridad
                            </th>

                            <th class="text-center"  scope="col">
                                Responsable
                            </th>

                            <th class="text-center" scope="col">
                                Estatus
                            </th>

                            <th class="text-center" scope="col">
                                Fecha límite
                            </th>

                            <th class="text-center" scope="col">
                                
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                    </tbody>

                </table>

            </div>

            <div id="sinResultados"
                 class="text-center text-muted py-4 d-none">
                No se encontraron tareas.
            </div>

            <div class="d-flex flex-column flex-md-row
                        justify-content-between
                        align-items-md-center gap-3 mt-3">

                <span id="totalRegistros"
                      class="text-muted">
                </span>

                <nav aria-label="Paginación de tareas">
                    <ul id="paginacion"
                        class="pagination mb-0">
                    </ul>
                </nav>

            </div>

        </div>
    </div>

</div>

@* Modal *@
<div class="modal fade"
     id="modalConfirmacion"
     tabindex="-1"
     aria-labelledby="modalConfirmacionLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">

                <h2 class="modal-title fs-5"
                    id="modalConfirmacionLabel">
                    Confirmar eliminación
                </h2>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>

            </div>

            <div class="modal-body">

                <p class="mb-0">
                    ¿Deseas eliminar la tarea
                    <strong id="modalTituloTarea"></strong>?
                </p>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="button"
                        id="confirmBtn"
                        class="btn btn-danger">
                    Eliminar
                </button>

            </div>

        </div>
    </div>

</div>

